# Required. A GitHub personal access token (classic or fine-grained, no scopes
# needed for public data). The Search Commits API does not work unauthenticated.
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=

# Optional. Uses a separate token for the history chart's GitHub GraphQL and
# commit search calls, so profile cards keep their own rate-limit budget.
# GITHUB_HISTORY_TOKEN=

# Optional. Used for absolute share URLs.
# NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Optional. Set to 1 to skip GitHub entirely and serve synthetic data for any
# /u/<login> page. Useful for design work and demos without burning rate limit.
# MOCK_PROFILE=1

# Optional. Vercel KV (Upstash Redis) — required for "Recently revealed" to
# accumulate beyond the seed list. Provision a KV store in the Vercel dashboard
# and run `vercel link` + `vercel env pull` to populate these locally. Without
# them the homepage falls back to a hardcoded seed list.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
